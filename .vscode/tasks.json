{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile extension (hidden)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "presentation": {
        "reveal": "never",
        "focus": false,
        "panel": "shared",
        "close": true
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "isBackground": true,
      "problemMatcher": [
        "$tsc-watch"
      ],
      "group": "build"
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "test"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "npm: test:e2e:vscode",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "test:e2e:vscode"
      ],
      "problemMatcher": [],
      "group": "test",
      "dependsOn": "compile extension (hidden)"
    },
    {
      "label": "Run UX Cognitive Audit",
      "type": "shell",
      "command": "node",
      "args": [
        "scripts/ux-cognitive-audit.js"
      ],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "close": false
      },
      "problemMatcher": [],
      "group": "test",
      "dependsOn": "compile extension (hidden)"
    },
    {
      "label": "Preview ComparisonPanel (Results)",
      "type": "shell",
      "command": "node",
      "args": [
        "dist/tools/openComparisonPreview.js",
        "--mode",
        "results"
      ],
      "dependsOn": "compile extension (hidden)",
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "Preview ComparisonPanel (Selection)",
      "type": "shell",
      "command": "node",
      "args": [
        "dist/tools/openComparisonPreview.js",
        "--mode",
        "selection"
      ],
      "dependsOn": "compile extension (hidden)",
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "close": false
      },
      "problemMatcher": []
    }
  ]
}