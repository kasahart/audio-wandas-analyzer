{
  "name": "audio-wandas-analyzer",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.extension-test-runner"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "audioWandasAnalyzer.pythonCommand": "${containerWorkspaceFolder}/.venv/bin/python",
        "files.exclude": {
          "**/.git": true,
          "**/.DS_Store": true
        }
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends libsndfile1 && npm install && python3 -m venv .venv && ./.venv/bin/pip install -r python-backend/requirements.txt",
  "postStartCommand": "npm run compile",
  "containerEnv": {
    "PYTHONUNBUFFERED": "1"
  }
}
