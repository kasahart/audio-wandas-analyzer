{
    "name": "audio-wandas-analyzer",
    "displayName": "Audio Wandas Analyzer",
    "description": "Analyze audio files in VS Code with a TypeScript extension UI and a Python backend powered by wandas.",
    "version": "0.0.5",
    "publisher": "audio-wandas-analyzer",
    "repository": {
        "type": "git",
        "url": "https://github.com/kasahart/audio-wandas-analyzer"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension/index.js",
    "contributes": {
        "commands": [
            {
                "command": "audioWandasAnalyzer.analyzeFile",
                "title": "%command.analyzeFile.title%"
            },
            {
                "command": "audioWandasAnalyzer.analyzeThisTarget",
                "title": "%command.analyzeThisTarget.title%"
            },
            {
                "command": "audioWandasAnalyzer.analyzeDebugFile",
                "title": "%command.analyzeDebugFile.title%"
            },
            {
                "command": "audioWandasAnalyzer.selectPythonEnvironment",
                "title": "%command.selectPythonEnvironment.title%"
            },
            {
                "command": "audioWandasAnalyzer.runRecipe",
                "title": "%command.runRecipe.title%"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "audioWandasAnalyzer.analyzeThisTarget",
                    "when": "resourceExtname =~ /^\\.(wav|flac|ogg|aiff|aif|snd)$/i",
                    "group": "2_workspace"
                },
                {
                    "command": "audioWandasAnalyzer.analyzeThisTarget",
                    "when": "explorerResourceIsFolder",
                    "group": "2_workspace"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "audioWandasAnalyzer",
                    "title": "%viewsContainer.title%",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "audioWandasAnalyzer": [
                {
                    "id": "audioWandasAnalyzer.welcomeView",
                    "name": "%views.welcomeView.name%"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "audioWandasAnalyzer.welcomeView",
                "contents": "%viewsWelcome.contents%"
            }
        ],
        "configuration": {
            "title": "%configuration.title%",
            "properties": {
                "audioWandasAnalyzer.pythonCommand": {
                    "type": "string",
                    "default": "python3",
                    "description": "%configuration.pythonCommand.description%"
                },
                "audioWandasAnalyzer.defaultPeakCount": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "maximum": 20,
                    "description": "%configuration.defaultPeakCount.description%"
                },
                "audioWandasAnalyzer.debugFilePath": {
                    "type": "string",
                    "default": "media/debug",
                    "description": "%configuration.debugFilePath.description%"
                },
                "audioWandasAnalyzer.cacheMemoryMb": {
                    "type": "number",
                    "default": 1024,
                    "minimum": 64,
                    "description": "Maximum total bytes of cached audio (in MB) held in the persistent Python backend.",
                    "scope": "window"
                }
            }
        }
    },
    "scripts": {
        "compile": "node scripts/clean-dist.js && tsc -p ./ && node scripts/build-webview.js",
        "watch": "tsc -p ./ -watch & node scripts/watch-webview.js",
        "package": "npm run compile",
        "vscode:prepublish": "npm run compile",
        "package:vsix": "vsce package --no-yarn --allow-missing-repository --skip-license",
        "test": "npm run compile && node --test dist/test/**/*.test.js",
        "test:e2e:vscode": "npm run compile && if command -v xvfb-run >/dev/null 2>&1; then xvfb-run -a node dist/e2e/runVscodeE2E.js; else node dist/e2e/runVscodeE2E.js; fi",
        "verify": "bash scripts/verify.sh",
        "verify:e2e": "npm run test:e2e:vscode"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.6.2",
        "@vscode/test-electron": "^2.5.2",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^22.10.2",
        "@types/vscode": "^1.96.0",
        "jsdom": "^29.1.1",
        "typescript": "^5.7.2"
    }
}
