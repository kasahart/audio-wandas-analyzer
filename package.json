{
    "name": "audio-wandas-analyzer",
    "displayName": "Audio Wandas Analyzer",
    "description": "Analyze audio files in VS Code with a TypeScript extension UI and a Python backend powered by wandas.",
    "version": "0.0.4",
    "publisher": "audio-wandas-analyzer",
    "repository": {
        "type": "git",
        "url": "https://github.com/kasahart/audio-wandas-analyzer"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension/index.js",
    "contributes": {
        "commands": [
            {
                "command": "audioWandasAnalyzer.analyzeFile",
                "title": "Audio Analyzer: Analyze File or Folder"
            },
            {
                "command": "audioWandasAnalyzer.analyzeThisTarget",
                "title": "Analyze with Audio Analyzer"
            },
            {
                "command": "audioWandasAnalyzer.analyzeDebugFile",
                "title": "Audio Analyzer: Analyze Debug Path"
            },
            {
                "command": "audioWandasAnalyzer.selectPythonEnvironment",
                "title": "Audio Analyzer: Select Python Environment"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "audioWandasAnalyzer.analyzeThisTarget",
                    "when": "resourceExtname =~ /\\.(wav|flac|ogg|aiff|aif|snd)$/i",
                    "group": "2_workspace"
                },
                {
                    "command": "audioWandasAnalyzer.analyzeThisTarget",
                    "when": "explorerResourceIsFolder",
                    "group": "2_workspace"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "audioWandasAnalyzer",
                    "title": "Audio Analyzer",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "audioWandasAnalyzer": [
                {
                    "id": "audioWandasAnalyzer.welcomeView",
                    "name": "Audio Analyzer"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "audioWandasAnalyzer.welcomeView",
                "contents": "音声ファイルまたはフォルダを解析します。\n\n[ファイル・フォルダを選択して解析](command:audioWandasAnalyzer.analyzeFile)\n\nエクスプローラーで音声ファイルまたはフォルダを右クリックして「Analyze with Audio Analyzer」を選択することもできます。"
            }
        ],
        "configuration": {
            "title": "Audio Wandas Analyzer",
            "properties": {
                "audioWandasAnalyzer.pythonCommand": {
                    "type": "string",
                    "default": "python3",
                    "description": "Python command used to launch the analysis backend."
                },
                "audioWandasAnalyzer.defaultPeakCount": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "maximum": 20,
                    "description": "Number of dominant frequency peaks shown per channel."
                },
                "audioWandasAnalyzer.debugFilePath": {
                    "type": "string",
                    "default": "media/debug",
                    "description": "Debug audio file or directory path used by the Analyze Debug Path command. Relative paths are resolved from the first workspace folder."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "npm run compile",
        "vscode:prepublish": "npm run compile",
        "package:vsix": "vsce package --no-yarn --allow-missing-repository --skip-license",
        "test": "npm run compile && node --test dist/test/**/*.test.js",
        "test:e2e:vscode": "npm run compile && if command -v xvfb-run >/dev/null 2>&1; then xvfb-run -a node dist/e2e/runVscodeE2E.js; else node dist/e2e/runVscodeE2E.js; fi",
        "verify": "bash scripts/verify.sh",
        "verify:e2e": "npm run test:e2e:vscode"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.6.2",
        "@vscode/test-electron": "^2.5.2",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^22.10.2",
        "@types/vscode": "^1.96.0",
        "jsdom": "^29.1.1",
        "typescript": "^5.7.2"
    }
}
